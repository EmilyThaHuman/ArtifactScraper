# ArtifactScraper Environment Configuration Example
# Copy this file to .env and fill in the values for Railway deployment

# Basic Configuration
ANYCRAWL_NAME=ArtifactScraper
ANYCRAWL_DOMAIN=https://your-domain.railway.app
ANYCRAWL_API_PORT=8080

# Engine Configuration
ANYCRAWL_HEADLESS=true
ANYCRAWL_AVAILABLE_ENGINES=playwright,cheerio,puppeteer
ANYCRAWL_IGNORE_SSL_ERROR=true
ANYCRAWL_KEEPALIVE=true

# Security
ANYCRAWL_API_AUTH_ENABLED=true
ANYCRAWL_API_CREDITS_ENABLED=false

# Database Configuration
ANYCRAWL_API_DB_TYPE=sqlite
ANYCRAWL_API_DB_CONNECTION=/usr/src/app/db/database.db

# Redis Configuration (update with Railway Redis URL)
ANYCRAWL_REDIS_URL=redis://your-redis-url:6379

# Performance Settings
ANYCRAWL_MAX_CONCURRENCY=50
ANYCRAWL_MIN_CONCURRENCY=25

# User Agent
ANYCRAWL_USER_AGENT=ArtifactScraper/1.0 (+https://github.com/EmilyThaHuman/ArtifactScraper)

# Node.js Environment
NODE_ENV=production